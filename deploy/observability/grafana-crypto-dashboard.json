{
  "title": "Talos — Crypto Invariants",
  "uid": "talos-crypto",
  "tags": ["talos", "security", "crypto", "at-rest-encryption"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Orphan gauges — non-zero means data loss already occurred",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "actor_memory orphaned rows",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rows in actor_memory where value_key_id points at a missing encryption_keys row. Should be 0 always. Non-zero = DEK deleted without rewrapping.",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "talos_actor_memory_orphaned_rows",
          "legendFormat": "orphans"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "module_executions orphaned rows",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rows where payload_enc_key_id points at a missing DEK. Input/output ciphertext unrecoverable.",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "talos_module_execution_orphaned_rows",
          "legendFormat": "orphans"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "workflow_executions orphaned rows",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Rows where output_enc_key_id points at a missing DEK. Output data unrecoverable.",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "talos_workflow_execution_orphaned_rows",
          "legendFormat": "orphans"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Crypto-path failure rates",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "KEK decrypt failures / sec",
      "description": "provider=both means BOTH active and legacy failed — hard fail. provider=active means legacy is carrying the load.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "provider=\"both\"" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(talos_kek_decrypt_failures_total[5m]))",
          "legendFormat": "provider={{provider}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "memory-write failures / sec (by reason)",
      "description": "__memory_write__ hook persist failures. reason=crypto is the high-urgency one.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5
          },
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(talos_memory_write_failures_total[5m]))",
          "legendFormat": "reason={{reason}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "module_executions payload enc/dec failures / sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (op, stage) (rate(talos_module_payload_encryption_failures_total[5m]))",
          "legendFormat": "op={{op}} stage={{stage}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Vault backend",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Vault sealed state",
      "description": "1 = unsealed (healthy). 0 = sealed (all crypto ops will fail until unseal).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 12, "y": 16 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "SEALED", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UNSEALED", "color": "green" } } }
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "vault_core_unsealed",
          "legendFormat": "state"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Vault request p50/p99 latency",
      "description": "Every DEK decrypt traverses Vault transit. High p99 → slow controller reads.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 16, "x": 20, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, rate(vault_core_handle_request_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, rate(vault_core_handle_request_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "DEK cache size",
      "description": "TTL + write-path invalidation keep this bounded. Unbounded growth = leak.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "talos_dek_cache_size",
          "legendFormat": "deks in cache"
        }
      ]
    }
  ]
}
