# docker-compose.override.yml.example
#
# Copy this to docker-compose.override.yml to customize your local environment.
# This file is ignored by git and overrides settings in docker-compose.yml
#
# Usage: cp docker-compose.override.yml.example docker-compose.override.yml

services:
  # Example: Change controller port
  # controller:
  #   ports:
  #     - "8001:8000"  # Use port 8001 instead of 8000
  #   environment:
  #     RUST_LOG: debug  # More verbose logging

  # Example: Change frontend port
  # frontend:
  #   ports:
  #     - "3001:3000"  # Use port 3001 instead of 3000

  # Example: Expose PostgreSQL port (for external tools like pgAdmin)
  # postgres:
  #   ports:
  #     - "5433:5432"  # Expose on different port to avoid conflicts

  # Example: Add environment variables for development
  # controller:
  #   environment:
  #     RUST_BACKTRACE: 1
  #     CUSTOM_ENV_VAR: "value"

  # Example: Mount additional volumes for development
  # controller:
  #   volumes:
  #     - ./controller/config:/app/config:ro
