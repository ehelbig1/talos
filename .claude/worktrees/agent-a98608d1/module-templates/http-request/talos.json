{
  "name": "http-request",
  "version": "v1.0.0",
  "display_name": "HTTP Request",
  "description": "Make outbound HTTP requests to external APIs.",
  "category": "Network",
  "allowed_hosts": [
    "*"
  ],
  "config_schema": {
    "type": "object",
    "properties": {
      "METHOD": {
        "type": "string",
        "enum": [
          "GET",
          "POST",
          "PUT",
          "DELETE",
          "PATCH"
        ],
        "default": "GET"
      },
      "URL": {
        "type": "string"
      },
      "HEADERS": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "key": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          }
        }
      },
      "BODY": {
        "type": "string"
      },
      "TIMEOUT_MS": {
        "type": "number",
        "default": 5000
      }
    },
    "required": [
      "URL"
    ]
  }
}