# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
#
# Copy this to .env.production and fill in your actual values.
#
# ⚠️  SECURITY WARNINGS:
# - NEVER commit .env.production to version control
# - Use strong, randomly-generated secrets (see generation commands below)
# - Rotate secrets regularly (every 90 days recommended)
#
# Usage:
#   1. Copy: cp .env.production.example .env.production
#   2. Generate secrets: openssl rand -hex 32
#   3. Fill in all required values
#   4. Deploy: docker-compose -f docker-compose.prod.yml up -d
#
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

# ✅ REQUIRED: PostgreSQL password (Generate with: openssl rand -hex 32)
POSTGRES_PASSWORD=<REPLACE-WITH-SECURE-RANDOM-PASSWORD>

# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION (CRITICAL - REQUIRED)
# ----------------------------------------------------------------------------

# ✅ REQUIRED: Master encryption key (Generate with: openssl rand -hex 32)
# WARNING: If lost, all encrypted secrets become unrecoverable
TALOS_MASTER_KEY=<REPLACE-WITH-SECURE-RANDOM-KEY>

# ✅ REQUIRED: JWT secret (Generate with: openssl rand -hex 32)
JWT_SECRET=<REPLACE-WITH-SECURE-RANDOM-SECRET>

# ✅ REQUIRED: Controller↔Worker HMAC signing key (Generate with: openssl rand -hex 32)
# Must match the WORKER_SHARED_KEY set on the worker process.
WORKER_SHARED_KEY=<REPLACE-WITH-SECURE-RANDOM-KEY>

# ✅ REQUIRED: NATS authentication (Generate with: openssl rand -hex 16)
# Prevents unauthorized processes on the Docker network from injecting/stealing jobs.
NATS_USER=<REPLACE-WITH-USERNAME>
NATS_PASSWORD=<REPLACE-WITH-SECURE-RANDOM-PASSWORD>

# ✅ REQUIRED: Redis password (Generate with: openssl rand -hex 32)
REDIS_PASSWORD=<REPLACE-WITH-SECURE-RANDOM-PASSWORD>

# ✅ REQUIRED: Worker metrics auth token (Generate with: openssl rand -hex 16)
# Prometheus uses this to authenticate when scraping /metrics.
METRICS_AUTH_TOKENS=<REPLACE-WITH-SECURE-RANDOM-TOKEN>

# ----------------------------------------------------------------------------
# PRODUCTION DOMAINS (REQUIRED)
# ----------------------------------------------------------------------------

# ✅ REQUIRED: Backend API URL (with https://)
BASE_URL=https://api.yourdomain.com

# ✅ REQUIRED: Frontend URL (with https://)
FRONTEND_URL=https://app.yourdomain.com

# ----------------------------------------------------------------------------
# RATE LIMITING (PRODUCTION - Stricter than development)
# ----------------------------------------------------------------------------

API_RATE_LIMIT=60          # GraphQL API: 60 req/min per IP
WEBHOOK_RATE_LIMIT=30      # Webhooks: 30 req/min per IP
GLOBAL_RATE_LIMIT=5000     # Global: 5000 req/min total
TRUSTED_IPS=               # Optional: Comma-separated whitelist IPs

# ----------------------------------------------------------------------------
# OAUTH PROVIDERS (OPTIONAL - Configure as needed)
# ----------------------------------------------------------------------------

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/auth/oauth/google/callback

# Okta OAuth
OKTA_DOMAIN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_REDIRECT_URI=https://api.yourdomain.com/auth/oauth/okta/callback

# Snyk OAuth
SNYK_CLIENT_ID=
SNYK_CLIENT_SECRET=
SNYK_REDIRECT_URI=https://api.yourdomain.com/auth/oauth/snyk/callback

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://api.yourdomain.com/api/slack/callback

# Gmail Integration
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://api.yourdomain.com/api/gmail/callback

# ============================================================================
# PRODUCTION FEATURES (AUTO-ENABLED in docker-compose.prod.yml)
# ============================================================================
#
# These features are AUTOMATICALLY enabled (RUST_ENV=production):
# ✅ Strict Content Security Policy (no unsafe-inline, no unsafe-eval)
# ✅ HTTP Strict Transport Security (HSTS) with 1-year max-age
# ✅ Global rate limiter (prevents distributed DoS attacks)
# ✅ GraphiQL playground disabled (prevents schema enumeration)
# ✅ PostgreSQL port NOT exposed (internal Docker network only)
#
# ============================================================================
