FROM ollama/ollama:0.5.1@sha256:722ce8caba5f8b8bd2ee654b2e29466415be3071a704e3f4db1702b83c885f76

# Models baked into the image at build time.
#
# DEFAULT (dev onboarding): only the embedding model is baked — it's small
# (~670 MB), so `make up` succeeds on any machine without a large Docker disk.
# Semantic search and actor-memory embeddings work out of the box.
#
# The embedding model MUST match the embedding columns' dimension. The
# `vector(...)` columns are 1024-dim (migration 20260429120000, Voyage), and
# mxbai-embed-large emits 1024 dims — they agree. If you switch EMBED_MODEL,
# keep EMBEDDING_MODEL/EMBEDDING_DIMENSIONS (docker-compose.yml) and the column
# dimension in lockstep, or pgvector rejects every write at INSERT time.
#
# Tier-1 LOCAL LLM models (qwen2.5:32b etc.) are OPT-IN. They are huge — baking
# qwen2.5:32b into the image needs ~30 GB of free Docker-VM disk, and a fresh
# `make up` without that headroom used to fail mid-build with a cryptic
# "no space left on device" (and leave a 24 GB half-built image behind). They're
# only needed by agents that must keep data on-host (sensitive actors: medical,
# financial, relationship content), so they default OFF.
#
# Enable tier-1 local LLM (set in .env, then `make rebuild SERVICE=ollama`):
#   TIER1_MODEL=qwen2.5:32b        # ~20 GB on disk, fits 32 GB RAM (Q4_K_M)
# Or directly:
#   docker compose build --build-arg TIER1_MODEL=qwen2.5:32b ollama
# Multiple models — comma-separated (include `mistral` if workflows hardcode it,
# since the Ollama provider falls back to `mistral` when no model is specified):
#   TIER1_MODEL=qwen2.5:32b,mistral
# Larger hardware (~64 GB RAM; stronger reasoning, ~3x slower generation):
#   TIER1_MODEL=llama3.3:70b
# All expose the same OpenAI-compatible API the controller already uses.

# Embedding model — always baked; required for semantic search. 1024-dim to
# match the embedding columns (see note above).
ARG EMBED_MODEL=mxbai-embed-large
ENV EMBED_MODEL=${EMBED_MODEL}

# Tier-1 local LLM models — comma-separated, OPT-IN, empty by default.
ARG TIER1_MODEL=
ENV TIER1_MODEL=${TIER1_MODEL}

# `set -eu` so a failed embed-model pull aborts the build loudly rather than
# producing an image that silently can't embed. The trailing `kill ... || true`
# must not abort, so it's guarded.
RUN set -eu; \
    ollama serve & \
    SERVER_PID=$!; \
    sleep 5; \
    ollama pull "${EMBED_MODEL}"; \
    for m in $(echo "${TIER1_MODEL}" | tr ',' ' '); do \
        if [ -n "$m" ]; then ollama pull "$m"; fi; \
    done; \
    kill "$SERVER_PID" 2>/dev/null || true
